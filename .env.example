# Director brain (required)
ANTHROPIC_API_KEY=sk-ant-...

# Image backend (required for `shoot` with the default replicate backend)
REPLICATE_API_TOKEN=r8_...

# Only needed for --backend gpt-image
# OPENAI_API_KEY=sk-...

# Only needed for --backend fal
# FAL_KEY=...

# Only needed for --backend comfyui
# COMFYUI_URL=http://127.0.0.1:8188
# COMFYUI_WORKFLOW=./workflow-api.json

# Optional overrides
# ART_DIRECTOR_MODEL=claude-opus-4-8
# ART_DIRECTOR_BACKEND=replicate
# OPENAI_IMAGE_MODEL=gpt-image-1
# REPLICATE_DRAFT_MODEL=black-forest-labs/flux-schnell
# REPLICATE_FINAL_MODEL=black-forest-labs/flux-1.1-pro
# REPLICATE_REF_DRAFT_MODEL=black-forest-labs/flux-dev
# ART_DIRECTOR_ROUNDS=2
# ART_DIRECTOR_CANDIDATES=4
